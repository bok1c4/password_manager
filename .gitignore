# Binaries and Build Artifacts

# Root-level binaries (NOT tracked)
/pwman
/pwman-server
/main
/server
*.exe
*.exe~
*.dll
*.so
*.dylib

# Build directories
dist/
src-tauri/target/

# Bin directory - track directory but ignore contents
/bin/*
!/bin/.gitkeep
!/bin/README.md

# Go
*.test
*.out
go.work

# Node
node_modules/
npm-debug.log*
yarn-error.log
yarn-debug.log*

# Environment Secrets
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Test Coverage
coverage.out
coverage.html

# Vault Data (CRITICAL - NEVER COMMIT!)
.pwman/
*.db
*.db-journal
private.key
public.key
*.key

# Logs
*.log

# Temporary
tmp/
temp/
